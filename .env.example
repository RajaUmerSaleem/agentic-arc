# GEMINI_API_KEY: Required for Gemini AI API calls (primary provider).
# Get yours at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted (used for self-referential links & OAuth).
APP_URL="http://localhost:3000"

# CIRCLE_API_KEY: Required for Circle Nanopayments.
# Format after May 2023: ENVIRONMENT:KEY_ID:SECRET (e.g. TEST_API_KEY:abc:def)
CIRCLE_API_KEY="YOUR_CIRCLE_API_KEY"

# CIRCLE_WALLET_ID: The source wallet UUID for the Coordinator agent.
CIRCLE_WALLET_ID="00000000-0000-0000-0000-000000000000"

# CIRCLE_APP_ID: Required for Circle Programmable Wallets.
CIRCLE_APP_ID="YOUR_CIRCLE_APP_ID"

# ENTITY_SECRET: A 32-byte hex string for developer-controlled wallets.
ENTITY_SECRET="YOUR_ENTITY_SECRET"

# FALLBACK_AI_API_KEY: Backup AI provider (OpenAI-compatible, e.g. Featherless, Groq, OpenRouter).
# Used when Gemini API quota is exhausted.
FALLBACK_AI_API_KEY="YOUR_FALLBACK_API_KEY"

# FALLBACK_AI_BASE_URL: Base URL for the fallback AI provider.
# Examples:
#   Featherless: https://api.featherless.ai/v1
#   Groq:        https://api.groq.com/openai/v1
#   OpenRouter:  https://openrouter.ai/api/v1
FALLBACK_AI_BASE_URL="https://api.featherless.ai/v1"

# FALLBACK_AI_MODEL: Model ID for the fallback provider.
# Examples: Qwen/Qwen3-0.6B, gpt-3.5-turbo, llama-3-8b-8192
FALLBACK_AI_MODEL="Qwen/Qwen3-0.6B"
